# =============================================================
#  .htaccess  —  Copy this to your project root
# =============================================================

# ---- SECURITY: Block direct access to sensitive files ----
<FilesMatch "^(\.env|composer\.json|composer\.lock|\.gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "*.log">
    Order allow,deny
    Deny from all
</Files>

# Block access to includes/ folder directly
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct URL access to /includes/ folder
    RewriteRule ^includes/ - [F,L]

    # Force HTTPS on live server (uncomment on production)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ---- Disable directory listing ----
Options -Indexes

# ---- Security Headers ----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

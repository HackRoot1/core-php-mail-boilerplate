# =============================================================
#  .env  —  Environment Variables / Private Credentials
# =============================================================
#  !! NEVER commit this file to Git or upload to a public repo !!
#  Add .env to your .gitignore file.
#
#  Copy this file to your project root and fill in real values.
#  Change values per project — this file stays private.
# =============================================================

# ---- SMTP Email Settings (Gmail) ----
# Use a Gmail App Password — NOT your real Gmail password.
# How to get an App Password:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification
#   3. Search "App passwords" → Create one for "Mail"
#   4. Paste the 16-char code below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16char_app_password
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=My Website

# ---- Business / Admin Email ----
# Where YOU receive form submissions and notifications
BUSINESS_EMAIL=owner@yourdomain.com

# ---- Site Info ----
SITE_NAME=My Website
SITE_URL=https://www.yourdomain.com

# ---- Environment ----
# Options: development  (shows PHP errors — for local only)
#          production   (hides errors — always use on live server)
ENVIRONMENT=development

# ---- Timezone ----
# See full list: https://www.php.net/manual/en/timezones.php
TIMEZONE=Asia/Kolkata
